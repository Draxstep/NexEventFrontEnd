### Pila de ReactNative.Gradle ###
.gradle
**/construir/
!src/**/construir/

# Ignorar la configuración de la GUI de Gradle
configuración de la aplicación gradle

# Evite ignorar el archivo jar contenedor de Gradle (los archivos .jar generalmente se ignoran)
!gradle-wrapper.jar

# Evite ignorar las propiedades del contenedor de Gradle
!gradle-wrapper.propiedades

# Caché del proyecto
.gradletasknamecache

# Archivos generados por el complemento Gradle de Eclipse
# Núcleo de Eclipse
.proyecto
# Específico de JDT (Herramientas de desarrollo de Java de Eclipse)
.ruta de clases

